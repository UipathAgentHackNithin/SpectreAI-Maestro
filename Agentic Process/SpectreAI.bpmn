    <bpmn:scriptTask id="Activity_l9lDZX" name="Script exectuion" scriptFormat="JavaScript">
      <bpmn:documentation>Extract key fields from slack message</bpmn:documentation>
      <bpmn:extensionElements>
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
          <uipath:context>
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"vars":{"type":"object"},"metadata":{"type":"object"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"vars":"=vars","metadata":"=metadata"}]]></uipath:input>
          <uipath:output name="scriptResponse" type="jsonSchema" source="=result.response" var="scriptResponse" />
          <uipath:output name="Error" type="jsonSchema" source="=Error" var="error" />
        </uipath:mapping>
        <uipath:scriptVersion value="v3" />
      </bpmn:extensionElements>
      <bpmn:incoming>edge_Event_start-Activity_l9lDZX</bpmn:incoming>
      <bpmn:outgoing>edge_SM1gL9</bpmn:outgoing>
      <bpmn:script><![CDATA[const text = vars.response.event_payload;
const user = vars.response.user_id;

const event = JSON.parse(text);
const thread = event.ts;
const ticketText = event.text.replace(/\*/g, '');
const lines = ticketText.split('\n').map(l => l.trim()).filter(l => l !== '');

const fields = {};
const knownKeys = ['What team are you on?', 'Region affected', 'Issue type', 'Transaction ID', 'Issue description', 'Issue impact', 'Process Number/Name'];

for (let i = 0; i < lines.length; i++) {
  const line = lines[i];
  if (line === 'SPECTRE_TICKET') continue;
  if (knownKeys.some(k => line.includes(k))) {
    fields[line.trim()] = lines[i + 1] || '';
    i++;
  }
}

return {
  ticket_type: fields['Issue type'] || '',
  team: fields['What team are you on?'] || '',
  region: fields['Region affected'] || '',
  transaction_id: fields['Transaction ID'] || '',
  process_name: fields['Process Number/Name'] || '',
  description: fields['Issue description'] || '',
  impact: fields['Issue impact'] || '',
  thread_ts: thread,
  user_id: user,
  channelid: vars.response.channel_id
};]]></bpmn:script>
    </bpmn:scriptTask>
